# 每日高会 - 定时任务配置示例
# 添加到 crontab：crontab -e

# 每天凌晨 00:10 执行数据备份
10 0 * * * cd /opt/dailygh && bash bin/backup_ecs_data.sh >> /var/log/dailygh_backup.log 2>&1

# 可选：每3分钟执行一次 TFent 数据拉取（如果配置了 TOKEN）
# */3 * * * * cd /opt/dailygh && TOKEN="Bearer <YOUR_TOKEN>" bash bin/cron_tfent_ingest_example.sh

# 可选：每天凌晨 01:00 清理过期缓存
# 0 1 * * * cd /opt/dailygh && find archives -name "*.tmp" -type f -mtime +3 -delete

# 可选：每周日凌晨 02:00 清理旧的日志文件
# 0 2 * * 0 cd /opt/dailygh && find .local_logs -name "*.log" -type f -mtime +30 -delete
