  const mapYesterdayFans = new Map();
  for(const r of (yesterdayRows||[])){
    if(r.realName) mapYesterdayFans.set(String(r.realName), Number(r.fansNum||0));
  }
  const mapBaselineWeek = new Map();
  for(const r of (baselineWeekRows||[])){
    if(r.realName) mapBaselineWeek.set(String(r.realName), Number(r.fansNum||0));
  }
  const mapBaselineMonth = new Map();
  for(const r of (baselineMonthRows||[])){
    if(r.realName) mapBaselineMonth.set(String(r.realName), Number(r.fansNum||0));
  }
  // 计算指定日期的排名映射（按粉丝数降序）
  const prevSorted = (yesterdayRows||[]).slice().sort((a,b)=>Number(b.fansNum||0)-Number(a.fansNum||0));
  const prevRankMap = new Map();
  let prevRankCounter = 0;
  for (const pr of prevSorted) {
    prevRankCounter += 1;
    if (pr.realName) prevRankMap.set(String(pr.realName), prevRankCounter);
  }

  const sorted = (todayRows||[]).slice().sort((a,b)=>Number(b.fansNum||0)-Number(a.fansNum||0));
  let prevFans = null;
  const enriched = [];
  let rank = 0;
  for(const r of sorted){
    rank += 1;
    const fans = Number(r.fansNum||0);
    const diffPrev = prevFans==null? '' : (prevFans - fans);
    prevFans = fans;
    const yesFans = mapYesterdayFans.has(String(r.realName)) ? mapYesterdayFans.get(String(r.realName)) : null;
    const growth = (yesFans==null ? '' : (fans - Number(yesFans))); // 日涨幅（昨日为基准）
    const weekBase = mapBaselineWeek.has(String(r.realName)) ? mapBaselineWeek.get(String(r.realName)) : null;
    const monthBase = mapBaselineMonth.has(String(r.realName)) ? mapBaselineMonth.get(String(r.realName)) : null;
    const weekGrowth = (weekBase==null ? '' : (fans - Number(weekBase))); // 不回退
    const monthGrowth = (monthBase==null ? '' : (fans - Number(monthBase))); // 不回退
    // 排名变化
    const prevRank = prevRankMap.has(String(r.realName)) ? prevRankMap.get(String(r.realName)) : null;
    let rankChange = '';
    if (prevRank != null) {
      const diff = prevRank - rank; // 正数表示排名提升（数值变小）
      if (diff > 0) rankChange = `上升${diff}名`;
      else if (diff < 0) rankChange = `下降${Math.abs(diff)}名`;
      else rankChange = '持平';
    }

    enriched.push({
      排名: rank,
      姓名: r.realName || '',
      收藏数: Number(r.collectNum||0),
      点赞数: Number(r.likeNum||0),
      粉丝数: fans,
      涨幅: growth,
      本周涨幅: weekGrowth,
      本月涨幅: monthGrowth,
      与前一名差值: diffPrev,
      排名变化: rankChange,
      avatarUrl: r.avatarUrl || r.headPortrait || '',
      birthTs: (r.birthTs!=null && Number.isFinite(Number(r.birthTs))) ? Number(r.birthTs) : null,
      nickName: r.nickName || (nicknameFallbacks[r.realName] || ''),
      userId: (r.userId != null ? r.userId : (userIdFallbacks[r.realName] || null))
    });
  }
  return enriched;
}

