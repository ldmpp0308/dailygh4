function parseBirthTs(val){
  if(val == null) return null;
  if(typeof val === 'number'){
    const n = Number(val);
    if(!Number.isFinite(n)) return null;
    const ts = n > 1e10 ? n : n * 1000; // 兼容秒/毫秒
    return Number.isFinite(ts) ? ts : null;
  }
  const s = String(val);
  const m = s.match(/\b(\d{4})[-\/.](\d{2})[-\/.](\d{2})\b/);
  if(m){
    const iso = `${m[1]}-${m[2]}-${m[3]}T00:00:00Z`;
    const ts = Date.parse(iso);
    return Number.isFinite(ts) ? ts : null;
  }
  return null;
}
function findFirstBirthValDeep(obj){
  const keys = ['birthday','birthDay','birth_date','dateOfBirth','birth','出生时间','出生日期','birthdayDesc'];
  try{
    const stack = [obj];
    while(stack.length){
      const cur = stack.pop();
      if(cur && typeof cur === 'object'){
        for(const [k,v] of Object.entries(cur)){
          const kl = String(k).toLowerCase();
          if(keys.some(x => kl === String(x).toLowerCase())){
            return v;
          }
          if(v && typeof v === 'object') stack.push(v);
        }
      }
    }
  }catch(e){}
  return null;
}
function extractBirthTsFromPayload(payload){
  const d = payload?.data || {};
  const i = d?.info || payload?.info || {};
  const candidates = [
    d.birthday, d.birthDay, d.birth_date, d.dateOfBirth, d.birth, d['出生时间'], d['出生日期'], d.birthdayDesc,
    i.birthday, i.birthDay, i.birth_date, i.dateOfBirth, i.birth, i['出生时间'], i['出生日期'], i.birthdayDesc
  ];
  for(const v of candidates){
    const ts = parseBirthTs(v);
    if(Number.isFinite(ts)) return ts;
  }
  const deepVal = findFirstBirthValDeep(payload);
  const ts2 = parseBirthTs(deepVal);
  return Number.isFinite(ts2) ? ts2 : null;
}

function parseTextToRows(rawText){
  if(!rawText || !rawText.trim()) return [];
  let obj = null;
  try{ obj = JSON.parse(rawText); }catch(e){
    // 尝试提取第一个大括号段落再解析
    const m = rawText.match(/\{[\s\S]*\}/);
    if(m){ try{ obj = JSON.parse(m[0]); }catch(e2){ obj = null; } }
  }
  if(!obj || typeof obj !== 'object') return [];
  // 支持：完整HAR 或 直接接口JSON
  const rows = [];
  const entries = obj?.log?.entries;
  if(Array.isArray(entries)){
    for(const entry of entries){
      const textVal = entry?.response?.content?.text;
      if(!textVal) continue;
      let payload = null;
      try{ payload = JSON.parse(textVal); }catch(e){
        const mm = String(textVal).match(/\{[\s\S]*\}/);
        if(mm){ try{ payload = JSON.parse(mm[0]); }catch(e2){ payload=null; } }
      }
      if(!payload || typeof payload!=='object') continue;
      const data = payload.data || {};
      const info = data.info || {};
      const birthTs = extractBirthTsFromPayload(payload);
      rows.push({
        realName: data.realName || '',
        nickName: data.nickName || data.nick || (nicknameFallbacks[data.realName] || ''),
        collectNum: Number(info.collectNum||0),
        likeNum: Number(info.likeNum||0),
        fansNum: Number(info.fansNum||0),
        avatarUrl: data.headPortrait || data.starHeadPortrait || '',
        birthTs: (birthTs != null ? birthTs : (birthFallbacks[data.realName] ? Date.parse(birthFallbacks[data.realName]) : null)),
        userId: (data.userId != null ? data.userId : (userIdFallbacks[data.realName] || null))
      });
    }
  } else {
    // 直接接口JSON，结构与 payload 相同
    const data = obj.data || {};
    const info = data.info || {};
    const birthTs = extractBirthTsFromPayload(obj);
    if(data.realName || info.fansNum!=null){
      rows.push({
        realName: data.realName || '',
        nickName: data.nickName || data.nick || (nicknameFallbacks[data.realName] || ''),
        collectNum: Number(info.collectNum||0),
        likeNum: Number(info.likeNum||0),
        fansNum: Number(info.fansNum||0),
        avatarUrl: data.headPortrait || data.starHeadPortrait || '',
        birthTs: (birthTs != null ? birthTs : (birthFallbacks[data.realName] ? Date.parse(birthFallbacks[data.realName]) : null)),
        userId: (data.userId != null ? data.userId : (userIdFallbacks[data.realName] || null))
      });
    }
  }
  return rows;
}

