async function checkApiStatus() {
  updateApiStatus('checking', '检查API连接状态...');
  
  const clientId = resolveClientId();
  
  try {
    // 检查主API
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 5000);
    
    // 添加时间戳和随机参数，确保绕过缓存
    const timestamp = Date.now();
    const random = Math.random();
    const response = await fetch(`${API_BASE}/api/archives/latest?client_id=${encodeURIComponent(clientId)}&_t=${timestamp}&_r=${random}`, {
      method: 'GET',
      signal: controller.signal,
      cache: 'no-store',
      mode: 'cors',
      headers: {
        'Cache-Control': 'no-cache, no-store, must-revalidate, max-age=0',
        'Pragma': 'no-cache',
        'Expires': '0'
      }
    });
    
    clearTimeout(timeoutId);
    
    if (response.ok) {
      updateApiStatus('online', 'API服务正常，支持数据同步');
      return 'online';
    } else {
      throw new Error(`API返回错误: ${response.status}`);
    }
  } catch (error) {
    console.log('主API检查失败:', error);
    
    // 检查备用API
    try {
      const backupController = new AbortController();
      const backupTimeoutId = setTimeout(() => backupController.abort(), 3000);
      
      // 添加时间戳和随机参数，确保绕过缓存
      const backupTimestamp = Date.now();
      const backupRandom = Math.random();
      const backupResponse = await fetch(`${API_BASE}/api/archives/latest?client_id=${encodeURIComponent(clientId)}&_t=${backupTimestamp}&_r=${backupRandom}`, {
        method: 'GET',
        signal: backupController.signal,
        cache: 'no-store',
        mode: 'cors',
        headers: {
          'Cache-Control': 'no-cache, no-store, must-revalidate, max-age=0',
          'Pragma': 'no-cache',
          'Expires': '0'
        }
      });
      
      clearTimeout(backupTimeoutId);
      
      if (backupResponse.ok) {
        updateApiStatus('online', 'API服务正常，支持数据同步');
        return 'online';
      }
    } catch (backupError) {
      console.log('备用API也失败:', backupError);
    }
    
    // 所有API都失败
    updateApiStatus('offline', '离线模式：数据仅保存在本地，建议导出备份');
    return 'offline';
  }
}

