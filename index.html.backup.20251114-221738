function showInlineStatus(targetId, type, text, ms=2200){
  try{
    const el = document.getElementById(targetId);
    if(!el) return;
    el.textContent = text || '';
    el.classList.remove('success','error','info','show');
    if(type) el.classList.add(type);
    
    // 成功时添加高亮效果
    if(type === 'success') {
      el.style.backgroundColor = '#e8f5e8';
      el.style.padding = '4px 8px';
      el.style.borderRadius = '4px';
      el.style.fontWeight = '500';
      el.style.color = '#137333';
    } else if(type === 'error') {
      el.style.backgroundColor = '#fce8e6';
      el.style.padding = '4px 8px';
      el.style.borderRadius = '4px';
      el.style.fontWeight = '500';
      el.style.color = '#d93025';
    }
    
    void el.offsetWidth; // force reflow
    el.classList.add('show');
    clearTimeout(el._hideT);
    el._hideT = setTimeout(()=>{ 
      el.classList.remove('show');
      // 恢复正常样式
      setTimeout(() => {
        el.style.backgroundColor = '';
        el.style.padding = '';
        el.style.borderRadius = '';
        el.style.fontWeight = '';
        el.style.color = '';
      }, 300);
    }, ms);
  }catch(e){}
}

