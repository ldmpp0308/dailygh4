async function refreshAutoTab(force){
  if(autoTabState.loading && !force){
    return;
  }
  const btn = document.getElementById('autoRefreshBtn');
  const latestDateEl = document.getElementById('autoLatestDate');
  const prevDateEl = document.getElementById('autoPrevDate');
  const lastSyncEl = document.getElementById('autoLastSync');
  try{
    autoTabState.loading = true;
    btn?.setAttribute('disabled','disabled');
    updateAutoStatus('info', '正在从服务器获取最新数据...');
    const clientId = resolveClientId();
    // 添加时间戳和随机参数，确保绕过所有缓存层
    const timestamp = Date.now();
    const random = Math.random();
    const resp = await fetch(`${API_BASE}/api/archives/latest?client_id=${encodeURIComponent(clientId)}&raw=1&_t=${timestamp}&_r=${random}`, { 
      cache: 'no-store',
      headers: {
        'Cache-Control': 'no-cache, no-store, must-revalidate, max-age=0',
        'Pragma': 'no-cache',
        'Expires': '0'
      }
    });
    if(!resp.ok){
      throw new Error(`HTTP ${resp.status}`);
    }
    const payload = await resp.json();
    syncPayloadToLocal(payload);
    autoTabState.lastFetched = Date.now();
    const memberData = payload.memberData || {};
    const dates = Object.keys(memberData).sort();
    if(!dates.length){
      renderAutoTable([], {});
      updateAutoStatus('error', '服务器未返回有效日期数据');
      return;
    }
    const latestDate = dates[dates.length - 1];
    const monthStart = getMonthStart(latestDate);
    const monthDates = listDatesBetween(monthStart, latestDate);
    await ensureDateCoverage({
      clientId,
      dates: monthDates,
      memberDataMap: memberData,
      rawMap: payload.memberRaw || {}
    });
    let prevDate = dates.length >= 2 ? dates[dates.length - 2] : getPrevDateStr(latestDate);
    let todayRows = getStoredRowsForDate(latestDate);
    if((!todayRows || !todayRows.length) && memberData[latestDate]){
      todayRows = dedupeLatestRows(memberData[latestDate]);
    }
    
    let yesterdayRows = prevDate ? getStoredRowsForDate(prevDate) : [];
    if((!yesterdayRows || !yesterdayRows.length) && prevDate && memberData[prevDate]){
      yesterdayRows = dedupeLatestRows(memberData[prevDate]);
    }
    if((!yesterdayRows || !yesterdayRows.length) && prevDate){
      try{
        // 添加时间戳和随机参数，确保绕过缓存
        const historyTimestamp = Date.now();
        const historyRandom = Math.random();
        const historyResp = await fetch(`${API_BASE}/api/archives/history?client_id=${encodeURIComponent(clientId)}&date=${encodeURIComponent(prevDate)}&_t=${historyTimestamp}&_r=${historyRandom}`, { 
          cache: 'no-store',
          headers: {
            'Cache-Control': 'no-cache, no-store, must-revalidate, max-age=0',
            'Pragma': 'no-cache',
            'Expires': '0'
          }
        });
        if(historyResp.ok){
          const historyPayload = await historyResp.json();
          const histRows = Array.isArray(historyPayload.rows) ? dedupeLatestRows(historyPayload.rows) : [];
          if(histRows.length){
            yesterdayRows = histRows;
            try{ localStorage.setItem(storageKey(prevDate), JSON.stringify(histRows)); }catch(_){}
          }
        }
      }catch(error){
        console.warn('获取昨日历史失败', error);
      }
    }
    // 记录服务器端该日的最大时间戳（即使只有 HAR 日志也能识别）
    try{
      const rawMap = payload.memberRaw || {};
      const rawTextLatest = rawMap[latestDate] || '';
      const srvMaxIso = detectMaxTsForDateFromText(rawTextLatest, latestDate);
      window.__latestServerMaxIso = window.__latestServerMaxIso || {};
      if(srvMaxIso){ window.__latestServerMaxIso[latestDate] = srvMaxIso; }
    }catch(_){ /* 忽略解析错误 */ }

    // 若最新日期没有有效明细，进行友好回退：展示昨日完整数据并给出提示
    if(!todayRows || !todayRows.length){
      updateAutoStatus('warning', `最新日期 ${latestDate} 数据不完整（无有效明细），已回退展示昨日数据`);
      const displayDate = prevDate;
      const displayPrevDate = displayDate ? getPrevDateStr(displayDate) : null;
      const baselineWeekFallback = getBaselineRowsForMode('week', displayDate);
      const baselineMonthFallback = getBaselineRowsForMode('month', displayDate);
      const enrichedFallback = sortAndEnrich(yesterdayRows || [], [], baselineWeekFallback, baselineMonthFallback);
      const latestIsoFallback = displayDate ? getMaxIsoFromStoredRows(displayDate) : null;
      const prevIsoFallback = displayPrevDate ? getMaxIsoFromStoredRows(displayPrevDate) : null;
      renderAutoTable(enrichedFallback, {
        latestDate: displayDate,
        prevDate: displayPrevDate,
        latestIso: latestIsoFallback,
        prevIso: prevIsoFallback
      });
      if(latestDateEl) latestDateEl.textContent = displayDate || '—';
      if(prevDateEl) prevDateEl.textContent = displayPrevDate || '—';
      if(lastSyncEl) lastSyncEl.textContent = new Date(autoTabState.lastFetched).toLocaleString('zh-CN',{ hour12:false });
      return;
    }

    // 正常路径：最新日期有数据，按标准流程渲染
    const baselineWeek = getBaselineRowsForMode('week', latestDate);
    const baselineMonth = getBaselineRowsForMode('month', latestDate);
    const enriched = sortAndEnrich(todayRows, yesterdayRows, baselineWeek, baselineMonth);
    // 优先从 todayRows 中提取 latestIso（实际显示的数据，包含最新时间）
    const latestIso = getMaxIsoFromRows(todayRows) || (window.__latestServerMaxIso || {})[latestDate] || getMaxIsoFromStoredRows(latestDate);
    const prevIso = prevDate ? (getMaxIsoFromRows(yesterdayRows) || getMaxIsoFromStoredRows(prevDate)) : null;
    renderAutoTable(enriched, {
      latestDate,
      prevDate,
      latestIso,
      prevIso
    });
    if(latestDateEl) latestDateEl.textContent = latestDate || '—';
    if(prevDateEl) prevDateEl.textContent = prevDate || '—';
    if(lastSyncEl) lastSyncEl.textContent = new Date(autoTabState.lastFetched).toLocaleString('zh-CN',{ hour12:false });
    updateAutoStatus('success', '已获取最新服务器数据');
  }catch(err){
    console.error('refreshAutoTab error', err);
    updateAutoStatus('error', `拉取失败：${err.message || err}`);
  }finally{
    autoTabState.loading = false;
    btn?.removeAttribute('disabled');
  }
}
