function exportImage(){
  if(!lastPreview || !lastPreview.length){ showError('请先“解析并预览”'); return; }
  const todayDate = document.getElementById('todayDate').value || new Date().toISOString().split('T')[0];
  const node = document.getElementById('preview');
  if(!node){ showError('未找到预览区域'); return; }
  // 确保导出时从预览顶部开始，包含表头
  node.scrollTop = 0;
  const origBG = node.style.backgroundColor;
  // 为导出PNG添加专用样式类，确保日期区间居中且上下留白一致
  node.classList.add('export-png');
  // 参照整个已显示列居中对齐：将日期区间宽度设置为表格的实际宽度，并使用左右 margin: auto 居中
  const rangeBar = node.querySelector('.range-bar');
  const tableEl = node.querySelector('table');
  const prevRangeStyle = {
    width: rangeBar ? rangeBar.style.width : '',
    display: rangeBar ? rangeBar.style.display : '',
    marginLeft: rangeBar ? rangeBar.style.marginLeft : '',
    marginRight: rangeBar ? rangeBar.style.marginRight : '',
    marginTop: rangeBar ? rangeBar.style.marginTop : '',
    marginBottom: rangeBar ? rangeBar.style.marginBottom : ''
  };
  try{
    const tw = tableEl ? Math.max(tableEl.scrollWidth, tableEl.offsetWidth, tableEl.clientWidth) : 0;
    if(rangeBar && tw > 0){
      rangeBar.style.width = tw + 'px';
      rangeBar.style.display = 'block';
      rangeBar.style.marginLeft = 'auto';
      rangeBar.style.marginRight = 'auto';
    }
  }catch(e){}
  node.style.backgroundColor = '#ffffff';
  const scale = (window.devicePixelRatio && window.devicePixelRatio > 1) ? 2 : 1;
  // 使用元素的完整滚动宽高，避免截断内容
  const exportWidth = node.scrollWidth;
  const exportHeight = node.scrollHeight;
  html2canvas(node, { scale, useCORS: true, backgroundColor: '#ffffff', width: exportWidth, height: exportHeight })
    .then(canvas => {
      const link = document.createElement('a');
      const fileName = `高会数据_${todayDate}.png`;
      link.download = fileName;
      link.href = canvas.toDataURL('image/png');
      link.click();
      showSuccess(`已导出图片：${fileName}`);
    })
    .catch(e => { showError('导出图片失败：' + (e && e.message ? e.message : e)); })
    .finally(() => {
      node.style.backgroundColor = origBG;
      node.classList.remove('export-png');
      // 还原日期区间样式
      if(rangeBar){
        rangeBar.style.width = prevRangeStyle.width || '';
        rangeBar.style.display = prevRangeStyle.display || '';
        rangeBar.style.marginLeft = prevRangeStyle.marginLeft || '';
        rangeBar.style.marginRight = prevRangeStyle.marginRight || '';
        rangeBar.style.marginTop = prevRangeStyle.marginTop || '';
        rangeBar.style.marginBottom = prevRangeStyle.marginBottom || '';
      }
    });
}
