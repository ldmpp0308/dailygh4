function getStoredRowsForDate(dateStr){
  if(!dateStr) return [];
  try{ const v = localStorage.getItem(storageKey(dateStr)); return v ? JSON.parse(v) : []; }catch(e){ return []; }
}

function getWeekStart(dateStr){
  const d = new Date(dateStr);
  const day = d.getDay(); // 0=Sun,1=Mon,...
  const delta = -day; // Sunday as start (周日起始)
  const start = new Date(d);
  start.setDate(d.getDate() + delta);
  return start.toISOString().split('T')[0];
}
function getMonthStart(dateStr){
  const d = new Date(dateStr);
  const y = d.getFullYear(); const m = d.getMonth()+1;
  const mm = String(m).padStart(2,'0');
  return `${y}-${mm}-01`;
}
function inRange(dateStr, startStr, endStr){
  const t = new Date(dateStr).getTime();
  return t >= new Date(startStr).getTime() && t <= new Date(endStr).getTime();
}
function getBaselineRowsForMode(mode, todayDate){
  if(mode !== 'week' && mode !== 'month') return [];
  const dates = listStoredDates();
  if(!dates.length) return [];
  if(mode === 'week'){
    const start = getWeekStart(todayDate);
    const end = todayDate;
    const candidates = dates.filter(d=>inRange(d, start, end)).sort();
    const baselineDate = candidates[0] || start; // 取本周内最早有存档的日期
    return getStoredRowsForDate(baselineDate);
  } else {
    const start = getMonthStart(todayDate);
    const end = todayDate;
    const candidates = dates.filter(d=>d.startsWith(start.slice(0,7))).sort();
    const baselineDate = candidates[0] || start; // 取本月内最早有存档的日期
    return getStoredRowsForDate(baselineDate);
  }
}

function autoFillFromLocal(){
  const tdEl = document.getElementById('todayDate');
  const yDateEl = document.getElementById('yesterdayDate');
  const todayEl = document.getElementById('todayText');
  const yesterdayEl = document.getElementById('yesterdayText');
  const follow = document.getElementById('followTextDate')?.checked;
  // 若当日日期为空或开启“跟随文本日期”，尝试从文本识别并填充
  const detectedToday = detectLatestDateFromText(todayEl?.value || '');
  if(follow){
    if(detectedToday){ tdEl.value = detectedToday; showSuccess(`已识别并跟随文本日期（当日）：${detectedToday}`); }
  }else{
    if(!tdEl.value && detectedToday){ tdEl.value = detectedToday; showSuccess(`已识别当日日期：${detectedToday}`); }
    else if(tdEl.value && detectedToday && tdEl.value !== detectedToday){ showError(`文本日期(${detectedToday})与选择日期(${tdEl.value})不一致，已使用选择日期`); }
  }
  const todayDate = tdEl.value;
  // 读取当日原始文本并按 startedDateTime 校验/对齐
  const todayRaw = document.getElementById('todayText')?.value || '';
  const vToday = validateDateAgainstStartedDateTime(todayDate, todayRaw, { strategy: 'latest_for_day' });
  if(vToday.changed){ tdEl.value = vToday.date; todayDate = vToday.date; showSuccess(`已根据 startedDateTime 对齐为：${vToday.date}`); }
  if(vToday.reason === 'mismatch'){ return; }
  if(!todayDate){ showError('请先选择“当日日期”'); return; }
  // 昨日期
  const detectedYesterday = detectLatestDateFromText(yesterdayEl?.value || '');
  const computedYesterday = detectedYesterday || getPrevDateStr(todayDate);
  if(follow){ if(yDateEl) yDateEl.value = computedYesterday; }
  const yesterdayDate = (yDateEl && yDateEl.value && yDateEl.value.trim()) ? yDateEl.value : computedYesterday;
  const todayText = todayEl.value;
  const yesterdayText = yesterdayEl?.value || '';
  // 按最大 startedDateTime 优先规则校验/对齐昨日日期
  const vYesterday = validateDateAgainstStartedDateTime(yesterdayDate, yesterdayText, { strategy: 'latest' });
  const finalYesterdayDate = vYesterday.changed ? vYesterday.date : yesterdayDate;
  if(vYesterday.changed){ if(yDateEl) yDateEl.value = finalYesterdayDate; showSuccess(`已根据 startedDateTime 对齐为：${finalYesterdayDate}（昨日）`); }
  if(vYesterday.reason === 'mismatch'){ return; }
  // 若文本框为空，尝试根据日期从本地填充原始文本
  if (!todayText || !todayText.trim()) {
    try{
      const rawToday = localStorage.getItem(storageRawKey(todayDate));
      if (rawToday) {
        todayEl.value = rawToday;
        showSuccess('已自动填充当日原始文本');
      } else {
        // 当“当日”无本地文档时，自动选取最新的本地存档日期进行填充
        const dates = listStoredDates();
        const latest = dates.length ? dates[dates.length - 1] : null;
        if(latest){
          const rawLatest = localStorage.getItem(storageRawKey(latest));
          if(rawLatest){
            tdEl.value = latest;
            todayDate = latest;
            todayEl.value = rawLatest;
            showSuccess(`已自动选取最新存档：${latest}`);
            // 若昨日未选择，则跟随最新存档的前一天
            const latestPrev = getPrevDateStr(latest);
            if(yDateEl && (!yDateEl.value || !yDateEl.value.trim())){
              yDateEl.value = latestPrev;
            }
          } else {
            showError('无本地文档');
          }
        } else {
          showError('无本地文档');
        }
      }
    }catch(e){}
  }
  if (!yesterdayText || !yesterdayText.trim()) {
    try{
      const targetY = (yDateEl && yDateEl.value && yDateEl.value.trim()) ? yDateEl.value : finalYesterdayDate;
      const rawY = localStorage.getItem(storageRawKey(targetY));
      if (rawY) { yesterdayEl && (yesterdayEl.value = rawY); showSuccess('已自动填充指定日期原始文本'); } else { showError('无本地文档'); }
    }catch(e){}
  }
  let tRows = [];
  let yRows = [];
  let usedTodayLocal = false;
  let usedYesterdayLocal = false;
  const curTodayText = todayEl.value;
  const curYesterdayText = yesterdayEl?.value || '';
  if (curTodayText && curTodayText.trim()) {
    tRows = parseTextToRows(curTodayText);
    if(!tRows.length){
      try{
        const cachedToday = localStorage.getItem(storageKey(todayDate));
        if(cachedToday){
          tRows = JSON.parse(cachedToday);
          usedTodayLocal = true;
        }
      }catch(e){}
    }
  } else {
    try{
      const cachedToday = localStorage.getItem(storageKey(todayDate));
      if(cachedToday){
        tRows = JSON.parse(cachedToday);
        usedTodayLocal = true;
      }
    }catch(e){}
  }
  if (curYesterdayText && curYesterdayText.trim()) {
    yRows = parseTextToRows(curYesterdayText);
    if(!yRows.length){
      try{
        const cachedY = localStorage.getItem(storageKey(finalYesterdayDate));
        if(cachedY){
          yRows = JSON.parse(cachedY);
          usedYesterdayLocal = true;
        }
      }catch(e){}
    }
  } else {
    try{
      const cachedY = localStorage.getItem(storageKey(finalYesterdayDate));
      if(cachedY){
        yRows = JSON.parse(cachedY);
        usedYesterdayLocal = true;
      }
    }catch(e){}
  }
  if (tRows.length){
    lastTodayRows = tRows;
    const baselineWeek = getBaselineRowsForMode('week', todayDate);
    const baselineMonth = getBaselineRowsForMode('month', todayDate);
    lastPreview = sortAndEnrich(tRows, yRows, baselineWeek, baselineMonth);
    renderPreviewTable(lastPreview);
    let msg = '已根据所选日期更新预览';
    const parts = [];
    if (usedTodayLocal) parts.push('当日数据来自本地');
    if (usedYesterdayLocal) parts.push('昨日数据来自本地');
    if (parts.length) msg = parts.join('；');
    showSuccess(msg);
  }
  // 更新“最新 startedDateTime”显示
  updateDetectedTsLabels();
}

