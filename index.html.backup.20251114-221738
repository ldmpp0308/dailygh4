function uploadLocalBackup(){
  try{
    const rawMap = {};
    const dataMap = {};
    for(let i=0;i<localStorage.length;i++){
      const k = localStorage.key(i);
      if(!k) continue;
      if(k.startsWith('memberRaw:')){
        const d = k.split(':')[1];
        const value = localStorage.getItem(k);
        if(value && value.trim()) {
          rawMap[d] = value;
        }
      } else if(k.startsWith('memberData:')){
        const d = k.split(':')[1];
        const v = localStorage.getItem(k);
        try{ 
          const parsed = v ? JSON.parse(v) : [];
          if(Array.isArray(parsed) && parsed.length > 0) {
            dataMap[d] = parsed;
          }
        }catch(e){ 
          console.warn(`Invalid memberData for ${d}:`, e);
        }
      }
    }
    
    // 验证数据
    const rawCount = Object.keys(rawMap).length;
    const dataCount = Object.keys(dataMap).length;
    
    if(rawCount === 0 && dataCount === 0) {
      showInlineStatus('uploadStatus','error','❌ 没有可上传的数据，请先导入HAR文件或创建数据');
      return;
    }
    
    // 检查数据完整性
    if(rawCount === 0) {
      showInlineStatus('uploadStatus','warning','⚠️ 警告：没有原始文本数据，仅上传处理后的数据');
    } else if(dataCount === 0) {
      showInlineStatus('uploadStatus','warning','⚠️ 警告：没有处理后的数据，仅上传原始文本');
    }
    
    console.log(`准备上传数据: 原始文本=${rawCount}个日期, 处理数据=${dataCount}个日期`);
    
    const payload = { memberRaw: rawMap, memberData: dataMap, exportedAt: new Date().toISOString() };
    const dateCount = Array.from(new Set([ ...Object.keys(rawMap), ...Object.keys(dataMap) ])).length;
    const clientId = location.hostname || 'default';
    
    showInlineStatus('uploadStatus','info','正在上传数据...');
    
    // 优先同源 /api 代理（由 Pages Functions/_worker.js 转发到稳定 API 域名）
    fetch(`${API_BASE}/api/archives/upload?client_id=${encodeURIComponent(clientId)}`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload), mode: 'cors', cache: 'no-store'
    }).then(async (resp)=>{
      if(!resp.ok){ const t = await resp.text(); throw new Error(t || '上传失败'); }
      showInlineStatus('uploadStatus','success',`✅ 上传成功！共提交 ${dateCount} 个日期`);
      setLastSync(Date.now());
    }).catch(async (err)=>{
      console.warn('主API上传失败，尝试备用API:', err.message);
      // 回退：直接访问稳定 API 域名
      try{
        const resp2 = await fetch(`${API_BASE}/api/archives/upload?client_id=${encodeURIComponent(clientId)}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload), mode: 'cors', cache: 'no-store' });
        if(!resp2.ok){ 
          const t2 = await resp2.text(); 
          let errorMsg = t2 || '上传失败';
          try {
            const errorObj = JSON.parse(t2);
            if(errorObj.detail) errorMsg = errorObj.detail;
          } catch(e) {}
          throw new Error(errorMsg);
        }
        showInlineStatus('uploadStatus','success',`✅ 上传成功！共提交 ${dateCount} 个日期`);
        setLastSync(Date.now());
      }catch(err2){
        console.error('Upload error (fallback failed):', err2);
        let finalError = '上传失败';
        if(err2 && err2.message) {
          if(err2.message.includes('缺少')) {
            finalError = '数据格式错误：' + err2.message;
          } else if(err2.message.includes('NetworkError') || err2.message.includes('fetch') || err2.message.includes('Failed to fetch')) {
            finalError = '无法连接到服务器。数据已保存在本地，可使用"导出Excel"功能备份数据。';
          } else {
            finalError = err2.message;
          }
        } else if(err && err.message) {
          if(err.message.includes('NetworkError') || err.message.includes('fetch') || err.message.includes('Failed to fetch')) {
            finalError = '无法连接到服务器。数据已保存在本地，可使用"导出Excel"功能备份数据。';
          } else {
            finalError = err.message;
          }
        }
        showInlineStatus('uploadStatus','error',`❌ ${finalError}`);
      }
    });
  }catch(e){ 
    console.error('Upload exception:', e);
    showInlineStatus('uploadStatus','error',`上传异常：${e.message || e}`); 
  }
}

function rowsHaveMeaningfulDiff(serverRows, localRows){
  try{
    const toMap = (rows) => {
      const map = new Map();
      if(!Array.isArray(rows)) return map;
      for(const r of rows){
        const key = String(r?.realName || r?.nickName || r?.userId || '');
        if(!key) continue;
        map.set(key, {
          fans: Number(r?.fansNum || 0),
          collect: Number(r?.collectNum || 0),
          like: Number(r?.likeNum || 0)
        });
      }
      return map;
    };
    const serverMap = toMap(serverRows);
    const localMap = toMap(localRows);
    if(serverMap.size !== localMap.size) return true;
    for(const [key, sval] of serverMap.entries()){
      const lval = localMap.get(key);
      if(!lval) return true;
      if(sval.fans !== lval.fans || sval.collect !== lval.collect || sval.like !== lval.like){
        return true;
      }
    }
    return false;
  }catch(e){
    return true;
  }
}

// 从 rows 数组中提取最新的 startedDateTime（优先使用，因为这是实际显示的数据）
function getMaxIsoFromRows(rows){
  if(!Array.isArray(rows) || !rows.length) return null;
  let maxTs = -Infinity;
  let maxIso = null;
  for(const r of rows){
    if(!r) continue;
    const iso = r.startedDateTime ? String(r.startedDateTime) : '';
    if(!iso || iso.startsWith('1970-01-01')) continue;
    const ts = Date.parse(iso);
    if(Number.isFinite(ts) && ts > maxTs){
      maxTs = ts;
      maxIso = iso;
    }
  }
  return maxIso;
}

function getMaxIsoFromStoredRows(dateStr){
  if(!dateStr) return null;
  try{
    const stored = localStorage.getItem(storageKey(dateStr));
    if(!stored) return null;
    const rows = JSON.parse(stored);
    if(!Array.isArray(rows) || !rows.length) return null;
    let maxTs = -Infinity;
    let maxIso = null;
    for(const r of rows){
      if(!r) continue;
      const iso = r.startedDateTime ? String(r.startedDateTime) : '';
      if(!iso || iso.startsWith('1970-01-01')) continue;
      const ts = Date.parse(iso);
      if(Number.isFinite(ts) && ts > maxTs){
        maxTs = ts;
        maxIso = iso;
      }
    }
    return maxIso;
  }catch(e){
    return null;
  }
}

