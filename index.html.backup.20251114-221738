}

function dedupeLatestRows(rows){
  if(!Array.isArray(rows) || !rows.length) return [];
  const map = new Map();
  for(const r of rows){
    if(!r) continue;
    // 优先使用 realName，其次 userId，确保唯一性
    const realName = String(r.realName || '').trim();
    const userId = r.userId != null ? String(r.userId) : '';
    const key = realName || userId || String(r.nickName || '');
    if(!key) continue;
    
    const iso = r.startedDateTime ? String(r.startedDateTime) : '';
    let ts = 0;
    try{
      ts = iso ? Date.parse(iso) : 0;
    }catch(e){ ts = 0; }
    const prev = map.get(key);
    if(!prev || ts > prev.ts){
      map.set(key, { ts, row: r });
    }
  }
  return Array.from(map.values()).map(entry => entry.row);
}

function listDatesBetween(start, end){
  if(!start || !end) return [];
  const out = [];
  try{
    const startDate = new Date(start);
    const endDate = new Date(end);
    if(!Number.isFinite(startDate.getTime()) || !Number.isFinite(endDate.getTime())) return out;
    let cur = new Date(startDate);
    while(cur.getTime() <= endDate.getTime()){
      out.push(cur.toISOString().split('T')[0]);
      cur.setDate(cur.getDate() + 1);
    }
  }catch(e){}
  return out;
}

const pendingHistoryFetch = new Map();

async function ensureDateCoverage(options){
  const { clientId, dates, memberDataMap, rawMap } = options || {};
  if(!clientId || !Array.isArray(dates) || !dates.length) return;
  const unique = Array.from(new Set(dates.filter(Boolean))).sort();
  for(const date of unique){
    try{
      let storedRows = getStoredRowsForDate(date);
      if(!storedRows.length && memberDataMap && Array.isArray(memberDataMap[date])){
        const deduped = dedupeLatestRows(memberDataMap[date]);
        if(deduped.length){
          try{ localStorage.setItem(storageKey(date), JSON.stringify(deduped)); }catch(e){}
          storedRows = deduped;
        }
      }
      if(rawMap && rawMap[date]){
        try{ localStorage.setItem(storageRawKey(date), rawMap[date]); }catch(e){}
      }
      if(storedRows.length){
        continue;
      }
      if(pendingHistoryFetch.get(date)){
        await pendingHistoryFetch.get(date);
        continue;
      }
      const promise = (async ()=>{
        try{
          const payload = await fetchHistoryRows(clientId, date);
          const histRows = Array.isArray(payload?.rows) ? dedupeLatestRows(payload.rows) : [];
          if(histRows.length){
            try{ localStorage.setItem(storageKey(date), JSON.stringify(histRows)); }catch(e){}
          }
          if(payload?.memberRaw && payload.memberRaw[date]){
            try{ localStorage.setItem(storageRawKey(date), payload.memberRaw[date]); }catch(e){}
          }
        }catch(err){
          console.warn('ensureDateCoverage history fetch failed:', date, err);
        }finally{
          pendingHistoryFetch.delete(date);
        }
      })();
      pendingHistoryFetch.set(date, promise);
      await promise;
    }catch(e){
      console.warn('ensureDateCoverage error:', date, e);
    }
  }
}

async function fetchHistoryRows(clientId, date){
  const attempt = async (base) => {
    // 添加时间戳和随机参数，确保绕过缓存
    const timestamp = Date.now();
    const random = Math.random();
    const url = `${base}/api/archives/history?client_id=${encodeURIComponent(clientId)}&date=${encodeURIComponent(date)}&_t=${timestamp}&_r=${random}`;
    const resp = await fetch(url, { 
      mode: 'cors', 
      cache: 'no-store',
      headers: {
        'Cache-Control': 'no-cache, no-store, must-revalidate, max-age=0',
        'Pragma': 'no-cache',
        'Expires': '0'
      }
    });
    if(!resp.ok){
      const text = await resp.text();
      throw new Error(text || `历史接口失败(${resp.status})`);
    }
    return resp.json();
  };
  try{
    return await attempt('');
  }catch(e1){
    try{
      return await attempt(API_BASE || '');
    }catch(e2){
      return await attempt('https://api.dailygh4.com');
    }
  }
}

async function ensurePreviousDateData(latestDate, clientId){
  if(!latestDate) return;
  const prevDate = getPrevDateStr(latestDate);
  if(!prevDate) return;
  try{
    const cached = localStorage.getItem(storageKey(prevDate));
    if(cached){
      try{
        const arr = JSON.parse(cached);
        if(Array.isArray(arr) && arr.length) return;
      }catch(e){}
    }
  }catch(e){}
  try{
    const payload = await fetchHistoryRows(clientId, prevDate);
    const rows = Array.isArray(payload?.rows) ? payload.rows : [];
    if(!rows.length) return;
    const deduped = dedupeLatestRows(rows);
    if(!deduped.length) return;
    localStorage.setItem(storageKey(prevDate), JSON.stringify(deduped));
  }catch(err){
    console.warn('ensurePreviousDateData error:', err);
  }
}

function pullLatestBackup(){
  try{
    const clientId = location.hostname || 'default';
    
    // 检查当前API状态
    const apiStatusEl = document.getElementById('apiStatus');
    const isOffline = apiStatusEl && apiStatusEl.style.display !== 'none' && 
                     document.getElementById('apiStatusIcon')?.textContent === '🔴';
    
    if (isOffline) {
      showInlineStatus('pullStatus','info','离线模式：使用本地数据...');
      // 直接使用本地数据，不尝试网络请求
      showInlineStatus('pullStatus','success','离线模式：已使用本地存档');
      refreshDateOptions();
      return;
    }
    
    showInlineStatus('pullStatus','info','正在拉取最新存档...');
    
    // 优先同源 /api 代理
    fetch(`${API_BASE}/api/archives/latest?client_id=${encodeURIComponent(clientId)}`, { mode: 'cors', cache: 'no-store' })
      .then(async (resp)=>{
        if(!resp.ok){ const t = await resp.text(); throw new Error(t || '拉取失败'); }
        return resp.json();
      }).catch(async (err)=>{
        console.log('主API失败，尝试备用API:', err.message);
        try{
          const resp2 = await fetch(`${API_BASE}/api/archives/latest?client_id=${encodeURIComponent(clientId)}`, { mode: 'cors', cache: 'no-store' });
          if(!resp2.ok){ const t2 = await resp2.text(); throw new Error(t2 || '拉取失败'); }
          return resp2.json();
        }catch(err2){
          console.log('备用API失败，尝试本地存档:', err2.message);
          try{
            const resp3 = await fetch('archives/latest_localhost.json');
            if(!resp3.ok){ const t3 = await resp3.text(); throw new Error(t3 || '本地最新存档缺失'); }
            return resp3.json();
          }catch(err3){
            console.log('本地存档也失败:', err3.message);
            // 如果所有方式都失败，提供友好的错误信息
            throw new Error('无法连接到服务器，且本地存档不可用。请检查网络连接或稍后重试。');
          }
        }
      }).then(async (payload)=>{
        const rawMap = payload.memberRaw || {};
        const dataMap = payload.memberData || {};
        // 合并策略：仅补齐缺失或覆盖较旧版本，保留本地较新版本
        const serverMaxIsoMap = {};
        const unionDates = Array.from(new Set([ ...Object.keys(rawMap), ...Object.keys(dataMap) ])).sort();
        let updatedCount = 0, keptCount = 0;
        function getMaxIsoFromRowsForDate(rows, date){
          try{
            if(!Array.isArray(rows) || !rows.length || !date) return null;
            let maxTs = -Infinity; let maxIso = null;
            for(const r of rows){
              const iso = r && r.startedDateTime ? String(r.startedDateTime) : null;
              if(!iso) continue;
              const ds = iso.split('T')[0];
              if(ds !== date) continue;
              const ts = Date.parse(iso);
              if(Number.isFinite(ts) && ts > maxTs){ maxTs = ts; maxIso = iso; }
            }
            return maxIso;
          }catch(e){ return null; }
        }
        for(const d of unionDates){
          try{
            const srvRaw = rawMap[d] || '';
            const srvRowsRaw = Array.isArray(dataMap[d]) ? dataMap[d] : [];
            const srvRows = dedupeLatestRows(srvRowsRaw);
            let srvMaxIso = srvRaw ? detectMaxTsForDateFromText(srvRaw, d) : null;
            if(!srvMaxIso && srvRows.length){ srvMaxIso = getMaxIsoFromRowsForDate(srvRows, d); }
            const srvMax = srvMaxIso ? Date.parse(srvMaxIso) : null;
            if(srvMaxIso){
              serverMaxIsoMap[d] = srvMaxIso;
            }

            const locRaw = localStorage.getItem(storageRawKey(d)) || '';
            const locRowsStr = localStorage.getItem(storageKey(d));
            const locRows = locRowsStr ? (function(){ try{ return JSON.parse(locRowsStr); }catch(e){ return []; } })() : [];
            let locMaxIso = locRaw ? detectMaxTsForDateFromText(locRaw, d) : null;
            if(!locMaxIso && Array.isArray(locRows) && locRows.length){ locMaxIso = getMaxIsoFromRowsForDate(locRows, d); }
            const locMax = locMaxIso ? Date.parse(locMaxIso) : null;

            // 决策：若本地较新或同新，则保留本地；否则更新为服务器版本；若本地为空且服务器有，则写入
            const hasLocal = (!!locRaw && locRaw.trim()) || (Array.isArray(locRows) && locRows.length);
            const hasServer = (!!srvRaw && srvRaw.trim()) || (Array.isArray(srvRows) && srvRows.length);

            if(hasLocal && hasServer && locMax!=null && srvMax!=null){
              if(locMax > srvMax){ keptCount++; continue; }
              const sameTimestamp = Math.abs(locMax - srvMax) < 1;
              const rowsDifferent = rowsHaveMeaningfulDiff(srvRows, locRows);
              if(!rowsDifferent && sameTimestamp){ keptCount++; continue; }
              // 服务器较新或内容不同，覆盖
              try{ if(srvRaw && srvRaw.trim()) localStorage.setItem(storageRawKey(d), srvRaw); }catch(e){}
              try{ localStorage.setItem(storageKey(d), JSON.stringify(srvRows)); }catch(e){}
              updatedCount++; continue;
            }
            if(hasLocal && !hasServer){ keptCount++; continue; }
            if(!hasLocal && hasServer){
              try{ if(srvRaw && srvRaw.trim()) localStorage.setItem(storageRawKey(d), srvRaw); }catch(e){}
              try{ localStorage.setItem(storageKey(d), JSON.stringify(srvRows)); }catch(e){}
              updatedCount++; continue;
            }
            // 两边都没有有效数据，不做处理
          }catch(e){ /* 单个日期合并失败忽略 */ }
        }
        if(typeof showInfo==='function'){
          showInfo(`已合并服务器存档：保留本地 ${keptCount} 项，更新 ${updatedCount} 项`);
        }
        try{
          window.__latestServerMaxIso = serverMaxIsoMap;
        }catch(e){}
        // 刷新下拉并尝试切换到最新日期
        refreshDateOptions();
        let latestDate = null;
        let latestIsoFromServer = null;
        try{
          const dates = listStoredDates();
          latestDate = dates.length ? dates[dates.length - 1] : null;
          if(latestDate){
            const tdEl = document.getElementById('todayDate');
            const ydEl = document.getElementById('yesterdayDate');
            if(tdEl){ tdEl.value = latestDate; }
            if(ydEl){ ydEl.value = getPrevDateStr(latestDate); }
            fillRawTextForDate(latestDate, 'todayText');
            fillRawTextForDate(getPrevDateStr(latestDate), 'yesterdayText');
            showInfo(`已切换至 ${latestDate}`);
            latestIsoFromServer = getMaxIsoFromStoredRows(latestDate);
            const monthDates = listDatesBetween(getMonthStart(latestDate), latestDate);
            await ensureDateCoverage({
              clientId,
              dates: monthDates,
              memberDataMap: dataMap,
              rawMap
            });
          }
        }catch(e){}

        const finalizeView = () => {
        ensureNonDuplicateDates();
        autoFillFromLocal();
        updateDetectedTsLabels();
        try{
          const tdMaxEl = document.getElementById('todayMaxTs');
          const tdMaxTxt = (tdMaxEl && tdMaxEl.textContent || '').trim();
          const tdValEl = document.getElementById('todayDate');
          const tdVal = tdValEl ? tdValEl.value : '';
            const derivedMaxLocal = getMaxIsoFromStoredRows(tdVal);
            const derivedMaxServer = (window.__latestServerMaxIso || {})[tdVal];
            const displayMax = formatIsoForLabel(derivedMaxLocal || derivedMaxServer);
            if(tdMaxEl && displayMax){
              tdMaxEl.textContent = displayMax;
            }
            const finalText = (tdMaxEl && tdMaxEl.textContent || '').trim();
            if(!finalText || finalText === '—' || finalText === '-' || finalText === 'NaN'){
            showInlineStatus('pullStatus','error',`最新日期${tdVal ? ' '+tdVal : ''}内容为空或无有效 HAR 时间戳`);
          }else{
            showInlineStatus('pullStatus','success','拉取完成：已恢复最新存档');
            setLastSync(Date.now());
          }
        }catch(e){
          showInlineStatus('pullStatus','success','拉取完成：已恢复最新存档');
          setLastSync(Date.now());
        }
        };

        Promise.resolve()
          .then(()=> latestDate ? ensurePreviousDateData(latestDate, clientId) : null)
          .catch(err => console.warn('补充上一日数据失败:', err))
          .finally(finalizeView);
      }).catch(err=>{ showInlineStatus('pullStatus','error',`拉取失败：${err.message || err}`); });
  }catch(e){ showError('拉取异常'); }
}
