// 存档日期与备份相关函数（放入主脚本中）
function listStoredDates(){
  const dates = new Set();
  try{
    for(let i=0;i<localStorage.length;i++){
      const k = localStorage.key(i);
      if(!k) continue;
      if(k.startsWith('memberRaw:') || k.startsWith('memberData:')){
        const d = k.split(':')[1];
        if(d) dates.add(d);
      }
    }
  }catch(e){}
  return Array.from(dates).sort();
}

function refreshDateOptions(){
  const dates = listStoredDates();
  const descDates = dates.slice().reverse();
  const build = (selId) => {
    const sel = document.getElementById(selId);
    if(!sel) return;
    sel.innerHTML = '<option value="">— 选择存档日期 —</option>' + descDates.map(d=>`<option value="${d}">${d}</option>`).join('');
  };
  build('todayDateSelect');
  build('yesterdayDateSelect');
}

function exportLocalBackup(){
