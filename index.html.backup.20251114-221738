// 将 ISO 时间字符串格式化为 "YYYY-MM-DD HH:mm:ss"（不做时区换算，仅截取主体部分）
function formatDateTimeForDisplay(tsStr){
  if(!tsStr) return null;
  let s = String(tsStr).replace('T',' ');
  const idxZ = s.indexOf('Z');
  const idxPlus = s.lastIndexOf('+');
  const idxMinus = s.lastIndexOf('-');
  let cutIndex = -1;
  if(idxZ >= 0) cutIndex = idxZ; else if(idxPlus > 10) cutIndex = idxPlus; else if(idxMinus > 10) cutIndex = idxMinus;
  if(cutIndex > 0) s = s.slice(0, cutIndex);
  if(s.includes('.')) s = s.split('.')[0];
  // 仅保留到分钟（YYYY-MM-DD HH:mm）
  const parts = s.split(' ');
  if(parts.length === 2){
    const hhmm = parts[1].split(':').slice(0,2).join(':');
    return `${parts[0]} ${hhmm}`;
  }
  // 回退：截取到前16位（YYYY-MM-DD HH:mm）
  return s.slice(0,16);
}

