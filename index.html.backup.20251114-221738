function extractDateFromJsonObj(obj){
  try{
    // HAR: 优先取 entries 中“数值最大”的 startedDateTime 对应的日期；若不可解析则回退到“出现次数最多的日期”
    const entries = obj?.log?.entries;
    if(Array.isArray(entries) && entries.length){
      // 1) 先找最大 startedDateTime
      let maxTs = -Infinity;
      let maxDate = null;
      for(const e of entries){
        const t = e?.startedDateTime || e?.request?.startedDateTime || e?.response?.startedDateTime;
        if(!t) continue;
        const ts = Date.parse(String(t));
        const ds = String(t).split('T')[0];
        if(!Number.isFinite(ts) || !/\d{4}-\d{2}-\d{2}/.test(ds)) continue;
        if(ts > maxTs){ maxTs = ts; maxDate = ds; }
      }
      if(maxDate) return maxDate;
      // 2) 回退：按日期出现次数最多
      const counts = {};
      for(const e of entries){
        const t = e?.startedDateTime || e?.request?.startedDateTime || e?.response?.startedDateTime;
        if(!t) continue;
        const ds = String(t).split('T')[0];
        if(/\d{4}-\d{2}-\d{2}/.test(ds)){ counts[ds] = (counts[ds]||0)+1; }
      }
      const best = Object.keys(counts).sort((a,b)=>counts[b]-counts[a])[0];
      if(best) return best;
    }
    // 常见 payload: 尝试 obj.date / obj.data.date / obj.info.date / obj.data.info.date
    const candidates = [];
    const maybeDates = [obj?.date, obj?.data?.date, obj?.info?.date, obj?.data?.info?.date];
    for(const v of maybeDates){ if(typeof v === 'string'){ const m = v.match(/\d{4}-\d{2}-\d{2}/); if(m){ candidates.push(m[0]); } } }
    if(candidates.length) return candidates[0];
    // 兜底：在字符串化内容中扫描日期
    const text = JSON.stringify(obj);
    const matches = text.match(/\b\d{4}-\d{2}-\d{2}\b/g);
    if(matches && matches.length){ const cnt = {}; for(const d of matches){ cnt[d]=(cnt[d]||0)+1; } return Object.keys(cnt).sort((a,b)=>cnt[b]-cnt[a])[0]; }
  }catch(e){}
  return null;
}
function detectDateFromText(rawText){
  if(!rawText || !rawText.trim()) return null;
