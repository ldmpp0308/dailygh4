function renderAvatarGrid(rows){
  const grid = document.getElementById('avatarGrid');
  if(!grid){ return; }
  // 统一清洗头像 URL，修复可能的混合内容（http -> https）和协议相对地址（//），并支持 Worker 代理
  const normalizeAvatarUrl = (u) => {
    try{
      let s = String(u||'').trim();
      if(!s) return '';
      if(s.startsWith('//')) s = 'https:' + s;
      if(s.startsWith('http://')) return '/img?u=' + encodeURIComponent(s);
      if(s.startsWith('https://')) return s;
      // 其他情况（可能是裸域名或奇怪格式），尝试通过代理升级为 https
      return '/img?u=' + encodeURIComponent('https://' + s.replace(/^\+/, ''));
    }catch(e){ return ''; }
  };

  const seen = new Set();
  const itemsRaw = [];
  let idx = 0;
  for(const r of (rows || [])){
    const name = r.姓名 || r.realName || '';
    const origUrl = r.avatarUrl || r.headPortrait || r.starHeadPortrait || '';
    const url = normalizeAvatarUrl(origUrl);
    const birthTs = (r.birthTs!=null && Number.isFinite(Number(r.birthTs))) ? Number(r.birthTs) : null;
    const nickName = r.nickName || (nicknameFallbacks[r.realName] || '');
    if(!name) continue;
    if(seen.has(name)) continue;
    seen.add(name);
    itemsRaw.push({ name, url, origUrl, birthTs, nickName, _idx: idx++ });
  }
  const safeTs = (x) => (Number.isFinite(Number(x)) ? Number(x) : Infinity);
  itemsRaw.sort((a,b)=>{
    const ta = safeTs(a.birthTs);
    const tb = safeTs(b.birthTs);
    if(ta === tb){ return a._idx - b._idx; }
    return ta - tb; // 出生时间升序（更早出生排前）
  });
  // 指定顺序优先（14位）：官俊臣 张桂源 张函瑞 王橹杰 左奇函 陈奕恒 杨博文 杨涵博 张奕然 聂玮辰 陈思罕 魏子宸 李煜东 陈浚铭
  const preferredOrder = ['官俊臣','张桂源','张函瑞','王橹杰','左奇函','陈奕恒','杨博文','杨涵博','张奕然','聂玮辰','陈思罕','魏子宸','李煜东','陈浚铭'];
  const norm = (s) => String(s||'').trim().replace(/\s+/g,'');
  const byName = new Map(itemsRaw.map(it => [norm(it.name), it]));
  const chosen = [];
  for(const n of preferredOrder){ const it = byName.get(norm(n)); if(it){ chosen.push(it); } }
  // 若不足14位，用剩余按出生时间升序填充
  if(chosen.length < 14){
    for(const it of itemsRaw){ if(chosen.find(x => norm(x.name)===norm(it.name))) continue; chosen.push(it); if(chosen.length>=14) break; }
  }
  const items = chosen.slice(0,14);
  const fmt = (ts) => (Number.isFinite(Number(ts)) ? new Date(Number(ts)).toISOString().slice(0,10) : 'N/A');
  try{ console.log('[avatar-order:preferred]', items.map(it => ({ name: it.name, birth: fmt(it.birthTs), ts: it.birthTs }))); }catch(e){}
  grid.innerHTML = items.map(it => {
    const hasImg = !!String(it.url||'').trim();
    const imgHtml = `<img src="${hasImg ? it.url : ''}" alt="${it.name}" style="display:${hasImg?'block':'none'};" loading="lazy" data-orig-url="${encodeURIComponent(it.origUrl||'')}" data-fallback-tried="0" />`;
    const fallbackHtml = `<span class="avatar-fallback" aria-label="${it.name}" style="width:36px;height:36px;border-radius:50%;background:#e9ecef;display:${hasImg?'none':'inline-flex'};align-items:center;justify-content:center;color:#495057;font-size:14px;">${String(it.name).slice(0,1)}</span>`;
    return `<a class="avatar-item" href="person.html?name=${encodeURIComponent(it.name)}">${imgHtml}${fallbackHtml}<span class="avatar-name">${it.name}</span></a>`;
  }).join('');

  // 若图片加载失败，自动切换为首字母占位
  try{
    const imgs = grid.querySelectorAll('.avatar-item img');
    imgs.forEach(img => {
      img.addEventListener('error', () => {
        try{
          const tried = img.getAttribute('data-fallback-tried') || '0';
          const origEnc = img.getAttribute('data-orig-url') || '';
          const orig = decodeURIComponent(origEnc);
          // 若通过代理加载失败，尝试直接升级为 https 原始地址一次
          if((tried === '0') && img.src.startsWith(location.origin + '/img')){
            const upgraded = (orig || '').replace(/^http:\/\//, 'https://');
            if(upgraded && upgraded !== orig){
              img.setAttribute('data-fallback-tried','1');
              img.src = upgraded;
              return;
            }
          }
          img.style.display = 'none';
          const fallback = img.parentElement?.querySelector('.avatar-fallback');
          if(fallback) fallback.style.display = 'inline-flex';
        }catch(_){ /* noop */ }
      });
    });
  }catch(_){ /* noop */ }
}

