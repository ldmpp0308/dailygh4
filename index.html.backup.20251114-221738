<script>
// 版本标识（控制台输出，便于验证部署）
console.log('%c🎀 高会排行榜 v2025.11.14.2058', 'color: #8e73ff; font-size: 16px; font-weight: bold;');
console.log('Build time:', new Date().toISOString());
// 轻提示样式
try{
  const style = document.createElement('style');
  style.textContent = `.msg.info { background:#e7f5ff; color:#0b7285; border:1px solid #d0ebff; } .inline-msg{font-size:13px;color:#666;opacity:0;transition:opacity .3s ease;min-height:20px;display:inline-block;} .inline-msg.show{opacity:1;} .inline-msg.success{color:#137333;} .inline-msg.error{color:#d93025;} .inline-msg.info{color:#1a73e8;} .status-area{background:#fafafa;border-radius:6px;padding:8px 12px;border:1px solid #e8eaed;}`;
  document.head.appendChild(style);
}catch(e){}
// API 基址统一使用同源代理，Pages Worker 会转发到稳定 API 域名
const API_BASE = '';
let currentTab = 'auto';
let autoTabState = { loading: false, lastFetched: 0 };

function resolveClientId(){
  try{
    const host = (location && location.hostname || '').trim();
    if(!host || host === 'localhost' || host === '127.0.0.1'){
      return 'rank.dailygh4.com';
    }
    return host;
  }catch(_){
    return 'rank.dailygh4.com';
  }
}

function initTabSwitcher(){
  try{
    const buttons = document.querySelectorAll('.tab-switcher button[data-tab]');
    buttons.forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const tab = btn.getAttribute('data-tab');
        activateTab(tab);
      });
    });
    activateTab('auto', { force: true, suppressScroll: true });
  }catch(e){
    console.error('initTabSwitcher error', e);
  }
}

function activateTab(tab, options){
  if(!tab) return;
  if(currentTab === tab && tab === 'auto' && !options?.force){
    refreshAutoTab();
    return;
  }
  currentTab = tab;
  const panels = document.querySelectorAll('.tab-panel');
  panels.forEach(panel=>{
    const isMatch = panel.id === `tab-${tab}`;
    panel.classList.toggle('active', isMatch);
    if(isMatch){
      panel.removeAttribute('hidden');
    }else{
      panel.setAttribute('hidden','');
    }
  });
  const buttons = document.querySelectorAll('.tab-switcher button[data-tab]');
  buttons.forEach(btn=>{
    const isMatch = btn.getAttribute('data-tab') === tab;
    btn.classList.toggle('active', isMatch);
    btn.setAttribute('aria-selected', isMatch ? 'true' : 'false');
  });
  if(tab === 'auto'){
    refreshAutoTab(options?.force);
  }
}

function updateAutoStatus(state, message){
  const statusEl = document.getElementById('autoStatusText');
  if(!statusEl) return;
  statusEl.textContent = message || '';
  statusEl.classList.remove('success','error','info');
  if(state){
    statusEl.classList.add(state);
  }
}

function syncPayloadToLocal(payload){
  if(!payload || typeof payload !== 'object') return;
  const rawMap = payload.memberRaw || {};
  const dataMap = payload.memberData || {};
  for(const d of Object.keys(rawMap)){
    try{
      if(rawMap[d] && String(rawMap[d]).trim()){
        localStorage.setItem(storageRawKey(d), rawMap[d]);
      }
    }catch(_){}
  }
  for(const d of Object.keys(dataMap)){
    try{
      const srvRows = Array.isArray(dataMap[d]) ? dedupeLatestRows(dataMap[d]) : [];
      localStorage.setItem(storageKey(d), JSON.stringify(srvRows));
    }catch(_){}
  }
}

function formatNumberDisplay(val, opts){
  if(val === '' || val == null) return '';
  const num = Number(val);
  if(!Number.isFinite(num)) return '';
  if(opts?.withSign){
    if(num === 0) return '-';
    return (num > 0 ? '+' : '') + num.toLocaleString('zh-CN');
  }
  if(opts?.dashWhenZero && num === 0) return '-';
  return num.toLocaleString('zh-CN');
}

// 自动模式的渲染数据缓存（用于复选框切换时重新渲染）
let lastAutoRows = [];
let lastAutoMeta = {};

function renderAutoTable(rows, meta){
  const container = document.getElementById('autoPreview');
  if(!container){ return; }
  
  // 缓存数据供复选框切换使用
  lastAutoRows = rows || [];
  lastAutoMeta = meta || {};
  
  if(!rows || !rows.length){
    container.innerHTML = '<div class="muted">暂无数据</div>';
    try{ renderAvatarGrid([]); }catch(_){}
    return;
  }
  
  // 读取复选框状态
  const showCollect = document.getElementById('autoToggleCollect')?.checked || false;
  const showLike = document.getElementById('autoToggleLike')?.checked || false;
  const showFans = document.getElementById('autoToggleFans')?.checked !== false;
  const showWeekGrowth = document.getElementById('autoToggleWeekGrowth')?.checked || false;
  const showMonthGrowth = document.getElementById('autoToggleMonthGrowth')?.checked || false;
  
  const latestDisplay = meta?.latestIso ? formatDateTimeForDisplay(meta.latestIso) : (meta?.latestDate || '—');
  const prevDisplay = meta?.prevIso ? formatDateTimeForDisplay(meta.prevIso) : (meta?.prevDate || '—');
  const maxFans = Math.max(...rows.map(r=>Number(r.粉丝数||0)));
  const flameThreshold = 3000;
  
  const rangeHtml = `<div class="range-bar">日期区间：${prevDisplay || '—'} ~ ${latestDisplay || '—'}</div>`;
  
  // 动态构建表头（与手动模式一致）
  const headerCols = ['排名','姓名'];
  if (showCollect) headerCols.push('收藏数');
  if (showLike) headerCols.push('点赞数');
  if (showFans) headerCols.push('粉丝数');
  headerCols.push('距上一名','今日涨幅');
  if (showWeekGrowth) headerCols.push('本周涨幅');
  if (showMonthGrowth) headerCols.push('本月涨幅');
  headerCols.push('排名变化');
  
  let html = '<table><thead><tr>' + headerCols.map(h=>`<th>${h}</th>`).join('') + '</tr></thead><tbody>';
  
  for(const r of rows){
    const isEven = (Number(r.排名||0) % 2 === 0);
    const fans = Number(r.粉丝数||0);
    const pct = maxFans > 0 ? Math.round(fans / maxFans * 100) : 0;
    
    const growthRaw = (r.涨幅 === '' || r.涨幅 == null) ? null : Number(r.涨幅);
    const growthText = (growthRaw == null) ? '' : (growthRaw === 0 ? '-' : (growthRaw > 0 ? `+${growthRaw}` : `${growthRaw}`));
    const growthCls = (growthRaw == null || growthRaw === 0) ? '' : (growthRaw > 0 ? 'num-pos' : 'num-neg');
    const showFlame = (growthRaw != null && growthRaw > flameThreshold);
    
    const rankChangeText = r.排名变化 === '持平' ? '-' : (r.排名变化 || '');
    const rankChangeCls = rankChangeText.startsWith('上升') ? 'num-pos' : (rankChangeText.startsWith('下降') ? 'num-neg' : '');
    
    const diffPrevRaw = (r['与前一名差值'] === '' || r['与前一名差值'] == null) ? null : Number(r['与前一名差值']);
    const diffPrevText = (diffPrevRaw == null) ? '' : (diffPrevRaw === 0 ? '-' : `${diffPrevRaw}`);
    // 距上一名：不显示颜色，使用默认黑色
    
    const cells = [];
    cells.push(`<td>${r.排名}</td>`);
    cells.push(`<td>${r.姓名}</td>`);
    if (showCollect) cells.push(`<td>${r.收藏数 || ''}</td>`);
    if (showLike) cells.push(`<td>${r.点赞数 || ''}</td>`);
    
    if (showFans) {
      const fansCellStyleBase = `background-image: linear-gradient(to right, #fb8c00, #ffe082); background-size: ${pct}% 100%; background-repeat: no-repeat;`;
      const fansCellStyle = isEven ? fansCellStyleBase + ' background-color: #efefef; background-blend-mode: multiply;' : fansCellStyleBase;
      cells.push(`<td style="${fansCellStyle}">${fans.toLocaleString('zh-CN')}</td>`);
    }
    
    cells.push(`<td>${diffPrevText}</td>`);
    
    // 日涨幅（带火焰）
    cells.push(`<td><span class="growth-cell ${growthCls}">${growthText}${showFlame ? `<span class="flame-icon flame-left" aria-hidden="true" title="涨幅：${growthRaw}">🔥</span>` : ''}</span></td>`);
    
    // 本周涨幅
    if (showWeekGrowth) {
      const wgRaw = (r['本周涨幅'] === '' || r['本周涨幅'] == null) ? null : Number(r['本周涨幅']);
      const wgText = (wgRaw == null) ? '' : (wgRaw === 0 ? '-' : (wgRaw > 0 ? `+${wgRaw}` : `${wgRaw}`));
      const wgCls = (wgRaw == null || wgRaw === 0) ? '' : (wgRaw > 0 ? 'num-pos' : 'num-neg');
      cells.push(`<td><span class="growth-cell ${wgCls}">${wgText}</span></td>`);
    }
    
    // 本月涨幅
    if (showMonthGrowth) {
      const mgRaw = (r['本月涨幅'] === '' || r['本月涨幅'] == null) ? null : Number(r['本月涨幅']);
      const mgText = (mgRaw == null) ? '' : (mgRaw === 0 ? '-' : (mgRaw > 0 ? `+${mgRaw}` : `${mgRaw}`));
      const mgCls = (mgRaw == null || mgRaw === 0) ? '' : (mgRaw > 0 ? 'num-pos' : 'num-neg');
      cells.push(`<td><span class="growth-cell ${mgCls}">${mgText}</span></td>`);
    }
    
    cells.push(`<td><span class="${rankChangeCls}">${rankChangeText}</span></td>`);
    html += `<tr${isEven ? ' class="zebra-even"' : ''}>${cells.join('')}</tr>`;
  }
  
  html += '</tbody></table>';
  
  // 底部说明
  const noteHtml = `
    <div class="preview-notes" style="margin:12px 0 18px; padding-left:1ch; color:#606c76; font-size:12px; line-height:1.7;">
      <div><strong>说明：</strong></div>
      <div>1、今日涨幅：今日粉丝数 - 昨日粉丝数</div>
      <div>2、本周涨幅：今日粉丝数 - 本周最早有数据的日期的粉丝数</div>
      <div>3、本月涨幅：今日粉丝数 - 本月最早有数据的日期的粉丝数</div>
      <div>4、排名变化：与昨日排名对比，正数表示排名上升</div>
      <div>5、所有数据从 2025/10/10开始统计，在此之前的不支持查看</div>
    </div>`;
  
  container.innerHTML = rangeHtml + html + noteHtml;
  try{ renderAvatarGrid(rows); }catch(_){}
}

